# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# 個人 Chat ID（備用）
TELEGRAM_PERSONAL_CHAT_ID=

# === HTTP server ===
PORT=8080
# /run 端點的驗證密碼（n8n 觸發時需帶 ?key=...）
PASSWORD=change-me-to-a-long-random-string

# === 系統 ===
TZ=Asia/Taipei
PYTHONUNBUFFERED=1
